// 2180. Count Integers With Even Digit Sum  - return

class Solution {
    public int countEven(int num) {
        int ans =0;
        for(int i = 1;i<=num;i++){
            int sum =0 , temp =i;
            while(temp!=0){
                sum+=(temp%10);
                temp/=10;
            }
            if(sum%2==0){
                ans++;
            }
        }
        return ans;
    }
}